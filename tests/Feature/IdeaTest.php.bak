<?php
use App\Models\Idea;
use App\Models\User;

test('pertenece a un usuario', function () {
    $idea = Idea::factory()->create();
    expect($idea->user)->toBeInstanceOf(User::class);
});

test('tiene pasos', function () {
    $idea = Idea::factory()->create();
    $idea->steps()->create(['description' => 'Paso']);
    expect($idea->fresh()->steps)->toHaveCount(1);
});
